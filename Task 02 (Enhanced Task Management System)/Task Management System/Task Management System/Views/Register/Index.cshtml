
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Management System</title>
    <link rel="icon" type="image/png" sizes="16x16" href="~/assets/images/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/css/style.css">
    <link href="~/assets/vendor/sweetalert2/dist/sweetalert2.min.css" rel="stylesheet" />

    <link href="~/assets/css/LoginCSS.css" rel="stylesheet" />

</head>
<body>

    <div class="container-fluid vh-100">
        <div class="row h-100">
            <div class="col-lg-5 col-md-12 d-flex flex-column justify-content-center left">
                <i class="la la-tasks" style="font-size:120px;color:orange;margin-top:-50px;"></i>
                <h1>Task Management System</h1>
                <p>“A smarter system for a smarter leader — Step in and take control.”</p>
                <div class="input-box">
                    <form id="RegisterForm">
                        <label>Username</label>
                        <input type="text" id="UserName" placeholder="Enter Username" required class="form-control input" />
                        <label>Useremail</label>
                        <input type="email" id="UserEmail" placeholder="Enter Useremail" required class="form-control input" />
                        <label>Usercontact</label>
                        <input type="number" id="Usercontact" placeholder="Enter Usercontact" required class="form-control input" />
                        <label>Useraddress</label>
                        <input type="text" id="Useraddress" placeholder="Enter Useraddress" required class="form-control input" />
                        <label>Password</label>
                        <input type="password" id="UserPassword" placeholder="Password" required class="form-control input" />
                        <button type="submit" class="login-btn">Register</button>
                    </form>
                    <!-- 🔥 ADD THIS -->
                    <div class="text-center mt-3">
                        <span>Already have an account?</span>
                        <a href="/Login/Index" class="text-primary fw-bold">Login</a>
                    </div>
                </div>
                <div class="divider"></div>
                <div class="copy">
                    Copyright @DateTime.Now.Year. All rights reserved. Design & Developed by Task Management System
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex right">
                <img src="~/assets/images/Register.png" class="drop-float">
            </div>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/assets/vendor/sweetalert2/dist/sweetalert2.min.js"></script>

    <script src="~/assets/js/RegisterJS.js"></script>

</body>
</html>


